---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Héctor Martínez | Full-Stack Developer">
  <main class="min-h-screen flex flex-col justify-center items-center bg-slate-950 text-slate-200 px-6 py-12 font-sans relative overflow-hidden">
    
    <div class="max-w-3xl w-full bg-slate-900/50 border border-slate-800 p-8 md:p-12 rounded-3xl backdrop-blur-md shadow-2xl relative z-10">
      
      <div class="absolute -top-12 -left-12 w-48 h-48 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-xs font-mono text-emerald-400">
          <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
          Open to Opportunities
        </div>
        
        <button id="open-game-btn" class="inline-flex items-center gap-2 px-3 py-1.5 bg-amber-500/10 border border-amber-500/30 hover:border-amber-400/60 rounded-full text-xs font-mono text-amber-400 cursor-pointer transition-all hover:scale-105 active:scale-95">
          🎮 ¿Aburrido? Échate una partida
        </button>
      </div>

      <div class="text-center sm:text-left">
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-white">
          Héctor <span class="bg-gradient-to-r from-blue-500 via-blue-400 to-indigo-500 bg-clip-text text-transparent">Martínez</span>
        </h1>
        <h2 class="text-xl md:text-2xl font-mono text-blue-400 mt-4">
          Full-Stack Developer & TSE @ monday.com
        </h2>
        
        <p class="mt-6 text-slate-400 text-lg leading-relaxed max-w-xl mx-auto sm:mx-0">
          Soy un desarrollador generalista enfocado en la construcción de aplicaciones web robustas, optimización de bases de datos y la administración de entornos de sistemas eficientes.
        </p>
      </div>

      <div class="w-full h-[1px] bg-slate-800/60 my-8"></div>

      <div class="space-y-6">
        <h3 class="text-white font-bold text-xl tracking-wide uppercase font-mono text-center sm:text-left">
          Tech Stack
        </h3>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-5 bg-slate-950/60 border border-slate-800/80 rounded-2xl">
            <h4 class="text-blue-400 font-semibold font-mono text-sm uppercase tracking-wider mb-3">
              Development & Frameworks
            </h4>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">JavaScript</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">PHP</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">Astro</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">Tailwind CSS</span>
            </div>
          </div>

          <div class="p-5 bg-slate-950/60 border border-slate-800/80 rounded-2xl">
            <h4 class="text-indigo-400 font-semibold font-mono text-sm uppercase tracking-wider mb-3">
              Data & Infrastructure
            </h4>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">PostgreSQL</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">SQL</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">Docker</span>
              <span class="px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 rounded-lg text-sm font-mono">Arch Linux</span>
            </div>
          </div>
        </div>
      </div>

      <div class="w-full h-[1px] bg-slate-800/60 my-8"></div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full relative z-10">
        <a href="https://linkedin.com/in/tu-usuario" target="_blank" rel="noopener noreferrer" 
           class="w-full sm:w-auto px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl hover:scale-[1.02] active:scale-95 transition-all duration-300 flex items-center justify-center gap-3">
          <img src="/icons/link.svg" alt="LinkedIn" class="w-5 h-5 invert" />
          <span>LinkedIn</span>
        </a>

        <a href="https://github.com/clementthee" target="_blank" rel="noopener noreferrer" 
           class="w-full sm:w-auto px-8 py-3 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-white font-bold rounded-xl hover:scale-[1.02] active:scale-95 transition-all duration-300 flex items-center justify-center gap-3">
          <img src="/icons/git.svg" alt="GitHub" class="w-5 h-5 invert" />
          <span>GitHub</span>
        </a>

        <a href="mailto:clementthee@gmail.com" 
           class="w-full sm:w-auto px-8 py-3 bg-slate-900 border border-slate-700 hover:border-slate-600 text-slate-300 hover:text-white font-medium rounded-xl hover:scale-[1.02] active:scale-95 transition-all duration-300 flex items-center justify-center gap-3">
          <img src="/icons/gmail.svg" alt="Gmail" class="w-5 h-5 invert" />
          <span>Contacto</span>
        </a>
      </div>

    </div>

    <div id="game-modal" class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
      <div class="bg-slate-900 border border-slate-800 max-w-md w-full p-6 rounded-2xl shadow-2xl relative flex flex-col items-center">
        <button id="close-game-btn" class="absolute top-4 right-4 text-slate-500 hover:text-white font-mono text-sm cursor-pointer">✕ Cerrar</button>
        
        <h3 class="text-white font-bold font-mono text-lg mb-2">Astro Snake Game</h3>
        <p class="text-xs text-slate-400 font-mono mb-4 text-center">¡Cuidado con los Bugs 🐛 letales al subir de nivel!</p>
        
        <canvas id="gameCanvas" width="300" height="300" class="bg-slate-950 border border-slate-800 rounded-xl shadow-inner"></canvas>
        
        <div class="w-full sm:hidden grid grid-cols-3 gap-2 max-w-[180px] mt-6 select-none">
          <div></div>
          <button id="btn-up" class="bg-slate-800 border border-slate-700 active:bg-blue-600 active:border-blue-500 text-white font-bold py-3 rounded-xl flex items-center justify-center shadow-lg text-lg">▲</button>
          <div></div>
          <button id="btn-left" class="bg-slate-800 border border-slate-700 active:bg-blue-600 active:border-blue-500 text-white font-bold py-3 rounded-xl flex items-center justify-center shadow-lg text-lg">◀</button>
          <div class="bg-slate-950/40 border border-slate-800/50 rounded-xl"></div>
          <button id="btn-right" class="bg-slate-800 border border-slate-700 active:bg-blue-600 active:border-blue-500 text-white font-bold py-3 rounded-xl flex items-center justify-center shadow-lg text-lg">▶</button>
          <div></div>
          <button id="btn-down" class="bg-slate-800 border border-slate-700 active:bg-blue-600 active:border-blue-500 text-white font-bold py-3 rounded-xl flex items-center justify-center shadow-lg text-lg">▼</button>
          <div></div>
        </div>

        <div class="mt-4 flex justify-between w-full font-mono text-sm px-2">
          <span class="text-blue-400">Score: <span id="score-val">0</span></span>
          <button id="start-game-btn" class="text-amber-400 hover:text-amber-300 underline cursor-pointer">Reiniciar</button>
        </div>
      </div>
    </div>

    <footer class="mt-12 text-center text-sm text-slate-600 font-mono">
      <p>📍 Guatemala | © {new Date().getFullYear()} Héctor Martínez</p>
    </footer>
  </main>
</MainLayout>

<script>
  const modal = document.getElementById('game-modal');
  const openBtn = document.getElementById('open-game-btn');
  const closeBtn = document.getElementById('close-game-btn');
  const canvas = document.getElementById('gameCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  const scoreVal = document.getElementById('score-val');
  const restartBtn = document.getElementById('start-game-btn');

  const btnUp = document.getElementById('btn-up');
  const btnDown = document.getElementById('btn-down');
  const btnLeft = document.getElementById('btn-left');
  const btnRight = document.getElementById('btn-right');

  let snake = [{x: 10, y: 10}];
  let food = {x: 5, y: 5, type: 'postgres'};
  let bugs: {x: number, y: number}[] = [];
  let dx = 1;
  let dy = 0;
  let score = 0;
  let gameInterval: any = null;
  const gridSize = 15;
  const tileCount = 20;

  const foodIconMap: any = {
    'postgres': '🐘',
    'astro': '🚀',
    'docker': '🐋',
  };
  const foodTypes = Object.keys(foodIconMap);

  function openGame() {
    modal?.classList.remove('hidden');
    resetGame();
  }

  function closeGame() {
    modal?.classList.add('hidden');
    clearInterval(gameInterval);
  }

  function resetGame() {
    snake = [{x: 10, y: 10}];
    bugs = [];
    generateFood();
    dx = 1;
    dy = 0;
    score = 0;
    if(scoreVal) scoreVal.innerText = '0';
    clearInterval(gameInterval);
    gameInterval = setInterval(updateGame, 120);
  }

  function generateFood() {
    food.x = Math.floor(Math.random() * tileCount);
    food.y = Math.floor(Math.random() * tileCount);
    while (bugs.some(b => b.x === food.x && b.y === food.y)) {
      food.x = Math.floor(Math.random() * tileCount);
      food.y = Math.floor(Math.random() * tileCount);
    }
    food.type = foodTypes[Math.floor(Math.random() * foodTypes.length)];
  }

  function generateBug() {
    let bugX = Math.floor(Math.random() * tileCount);
    let bugY = Math.floor(Math.random() * tileCount);

    const collision = 
      snake.some(s => s.x === bugX && s.y === bugY) || 
      (food.x === bugX && food.y === bugY) ||
      bugs.some(b => b.x === bugX && b.y === bugY);

    if (!collision) {
      bugs.push({x: bugX, y: bugY});
    }
  }

  function updateGame() {
    let nextX = snake[0].x + dx;
    let nextY = snake[0].y + dy;

    if (nextX < 0) nextX = tileCount - 1;
    if (nextX >= tileCount) nextX = 0;
    if (nextY < 0) nextY = tileCount - 1;
    if (nextY >= tileCount) nextY = 0;

    const head = {x: nextX, y: nextY};
    
    const hitSelf = snake.some(s => s.x === head.x && s.y === head.y);
    const hitBug = bugs.some(b => b.x === head.x && b.y === head.y);

    if (hitSelf || hitBug) {
      clearInterval(gameInterval);
      alert(`Game Over! Un bug rompió tu código. Score final: ${score}`);
      return;
    }

    snake.unshift(head);

    if (head.x === food.x && head.y === food.y) {
      score += 10;
      if(scoreVal) scoreVal.innerText = score.toString();
      
      if (Math.random() < 0.6) { 
        generateBug();
      }

      if(ctx) {
        ctx.fillStyle = 'white';
        ctx.fillRect(food.x * gridSize, food.y * gridSize, gridSize, gridSize);
      }
      setTimeout(generateFood, 50);
    } else {
      snake.pop();
    }

    if(ctx) {
      ctx.fillStyle = '#020617';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.fillStyle = '#6366f1';
      snake.forEach(part => ctx.fillRect(part.x * gridSize, part.y * gridSize, gridSize - 1, gridSize - 1));

      ctx.font = '16px serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      bugs.forEach(bug => {
        ctx.fillText('🐛', (bug.x * gridSize) + (gridSize / 2), (bug.y * gridSize) + (gridSize / 2) + 1);
      });

      const currentIcon = foodIconMap[food.type];
      ctx.fillText(currentIcon, (food.x * gridSize) + (gridSize / 2), (food.y * gridSize) + (gridSize / 2) + 1);
    }
  }

  window.addEventListener('keydown', e => {
    if (!modal?.classList.contains('hidden')) {
      if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
        e.preventDefault();
      }
      if (e.key === 'ArrowUp' && dy === 0) { dx = 0; dy = -1; }
      if (e.key === 'ArrowDown' && dy === 0) { dx = 0; dy = 1; }
      if (e.key === 'ArrowLeft' && dx === 0) { dx = -1; dy = 0; }
      if (e.key === 'ArrowRight' && dx === 0) { dx = 1; dy = 0; }
    }
  });

  btnUp?.addEventListener('click', () => { if (dy === 0) { dx = 0; dy = -1; } });
  btnDown?.addEventListener('click', () => { if (dy === 0) { dx = 0; dy = 1; } });
  btnLeft?.addEventListener('click', () => { if (dx === 0) { dx = -1; dy = 0; } });
  btnRight?.addEventListener('click', () => { if (dx === 0) { dx = 1; dy = 0; } });

  openBtn?.addEventListener('click', openGame);
  closeBtn?.addEventListener('click', closeGame);
  restartBtn?.addEventListener('click', resetGame);
</script>