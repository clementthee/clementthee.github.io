---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Héctor Martínez | Full-Stack Developer">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" slot="head" />

  <main class="min-h-screen flex flex-col justify-center items-center bg-slate-950 text-slate-200 px-6 py-16 font-sans selection:bg-blue-500/30">
    
    <div class="max-w-2xl w-full bg-slate-900/40 border border-slate-800/80 p-8 md:p-12 rounded-3xl backdrop-blur-xl shadow-2xl relative overflow-hidden">
      
      <div class="absolute -top-24 -left-24 w-48 h-48 bg-blue-500/10 rounded-full blur-3xl"></div>
      
      <div class="text-center relative z-10">
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-white">
          Héctor <span class="bg-gradient-to-r from-blue-500 via-blue-400 to-indigo-500 bg-clip-text text-transparent">Martínez</span>
        </h1>
        <h2 class="text-xl md:text-2xl font-mono text-slate-400 mt-4 tracking-tight">
          Full-Stack Developer | TSE @ <span class="text-blue-400 font-semibold">monday.com</span>
        </h2>
        
        <p class="mt-6 text-slate-400 text-lg leading-relaxed max-w-lg mx-auto">
          Generalista autodidacta impulsado por la lógica y la optimización de sistemas. De compilar entornos eficientes en <span class="text-slate-200 font-mono text-sm bg-slate-800 px-1.5 py-0.5 rounded">Arch Linux</span> al desarrollo web robusto.
        </p>
      </div>

      <div class="w-full h-[1px] bg-slate-800 my-8"></div>

      <div class="flex flex-col gap-3.5 relative z-10">
        <a href="https://www.linkedin.com/in/hector-clemente-martinez-perez/" target="_blank" rel="noopener noreferrer" 
           class="group w-full px-6 py-4 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-2xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-200 flex items-center justify-between shadow-lg shadow-blue-600/10">
          <span class="flex items-center gap-3">💼 Conectemos en LinkedIn</span>
          <span class="transform group-hover:translate-x-1 transition-transform">→</span>
        </a>

        <a href="https://github.com/clementthee" target="_blank" rel="noopener noreferrer" 
           class="group w-full px-6 py-4 bg-slate-800/80 hover:bg-slate-700/80 border border-slate-700 text-white font-bold rounded-2xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-200 flex items-center justify-between">
          <span class="flex items-center gap-3 font-mono text-sm">💻 github.com/clementthee</span>
          <span class="transform group-hover:translate-x-1 transition-transform">→</span>
        </a>

        <a href="mailto:clementthee@gmail.com" 
           class="group w-full px-6 py-4 bg-slate-950/40 hover:bg-slate-900/60 border border-dashed border-slate-800 hover:border-slate-700 text-slate-300 font-medium rounded-2xl transition-all flex items-center justify-between">
          <span class="flex items-center gap-3">✉️ clementthee@gmail.com</span>
          <span>⚡</span>
        </a>
      </div>

      <div class="mt-8 grid grid-cols-2 gap-4 text-left relative z-10 text-xs font-mono">
        <div class="p-4 bg-slate-950/50 border border-slate-800/60 rounded-xl">
          <div class="text-blue-400 font-bold mb-1">🛠️ STACK</div>
          JavaScript, PHP, SQL, Docker, Astro.
        </div>
        <div class="p-4 bg-slate-950/50 border border-slate-800/60 rounded-xl">
          <div class="text-indigo-400 font-bold mb-1">🎯 INTERESES</div>
          Automación, Linux SysAdmin, Lab Projs.
        </div>
      </div>

    </div>

    <footer class="mt-12 text-center text-xs text-slate-600 font-mono tracking-wider">
      <p>📍 Guatemala | © {new Date().getFullYear()} Héctor Martínez</p>
    </footer>
  </main>
</MainLayout>

<style is:global>
  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }
</style>